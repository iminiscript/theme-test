
  <div class="cart-drawer__empty-state py-4">
    <div class="cart-drawer__empty-header text-center">
      {%- if settings.empty_cart_title != blank -%}
        <h2 class="cart-drawer__empty-title text-14-bold normal-case">
          {{ settings.empty_cart_title }}
        </h2>
      {%- endif -%}

      {%- if settings.empty_cart_subtitle != blank -%}
        <p class="cart-drawer__empty-subtitle text-14-light">
          {{ settings.empty_cart_subtitle }}
        </p>
      {%- endif -%}
    </div>

    {%- liquid
      assign has_collections = false

      for i in (1..6)
        assign col_key = 'empty_cart_collection_' | append: i
        assign img_key = col_key | append: '_image'
        assign col_obj = settings[col_key]

        if col_obj != blank and settings[img_key] != blank
          assign has_collections = true
          break
        endif
      endfor
    -%}

    {%- if has_collections -%}
      <div class="cart-drawer__empty-collections grid grid-cols-2 gap-3 text-left py-6">

        {%- for i in (1..6) -%}
          {%- assign col_key = 'empty_cart_collection_' | append: i -%}
          {%- assign img_key = col_key | append: '_image' -%}

          {%- assign col_obj = settings[col_key] -%}
          {%- assign col_image = settings[img_key] -%}

          {%- if col_obj != blank and col_image != blank -%}

            {%- assign col_title = col_image.alt | default: col_obj.title -%}

            <a href="{{ col_obj.url }}" class="cart-drawer__empty-collection-link no-underline text-black">
              <div class="cart-drawer__empty-collection-image-wrapper">
                {{
                  col_image
                  | image_url: width: 400
                  | image_tag:
                    loading: 'lazy',
                    widths: '165, 360, 400',
                    alt: col_title,
                    class: 'cart-drawer__empty-collection-image'
                }}
              </div>

              <p class="cart-drawer__empty-collection-title pt-1 text-12-regular">
                {{ col_title }}
                <span class="empty-collection-arrow -rotate-45 inline-block">
                  {% render 'icon', icon: 'pointer-arrow-right', class: 'w-3 h-3' %}
                </span>
              </p>
            </a>

          {%- endif -%}
        {%- endfor -%}

      </div>
    {%- endif -%}

    {%- if settings.empty_cart_button_text != blank -%}
      <button
        type="button"
        onclick="window.location.href='{% if settings.empty_cart_button_link != blank %}{{ settings.empty_cart_button_link }}{% else %}{{ routes.all_products_collection_url }}{% endif %}'"
        class="cart-drawer__empty-button btn btn-primary-orange btn-md w-full"
      >
        {{ settings.empty_cart_button_text }}
      </button>
    {%- endif -%}

  </div>


