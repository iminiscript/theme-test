          </svg>
          <span class="GWP__achievedText text-12-bold text-brunt-orange" data-gwp="achievedText">You've earned {{ achieved_label }}</span>
        </p>
        {%- endif -%}
        {%- if next_label != blank -%}
        <p class="m-0 text-center text-12-bold" data-gwp="nextAchievement">
          <span class="GWP__nextText" data-gwp="nextText">You're <span data-gwp="remainingAmount">{{ currency }}{{ remaining_cents | divided_by: 100.0 | round: 2 }}</span> away from {{ next_label }}</span>
        </p>
        {%- endif -%}
      </div>

    <div class="relative m-3 mb-2 text-12-bold gwp-progressbar-container">
      <div class="flex">
        {%- comment -%} First marker (threshold_0) - always at start {%- endcomment -%}
        <div class="flex flex-col flex-1 relative items-start text-12-bold" data-threshold="{{ threshold_0 }}" data-label="{{ label_0 }}" data-gwp="indicator">
          <div class="text-center">
            <p class="m-0 line-clamp-2 leading-tight min-h-[36px] text-left text-12-bold">
              {{ label_0 }}
            </p>
          </div>
          <div class="flex flex-col items-start">
            <div class="GWP__marker GWP__marker--start {% if marker_0_checked %} GWP__marker--checked{% endif %}" data-gwp="marker"></div>
            <p class="m-0 whitespace-nowrap text-12-bold">{{ threshold_0 | money_without_trailing_zeros }}</p>
          </div>
        </div>

        {%- comment -%} Loop through thresholds 1-4 {%- endcomment -%}
        {%- for i in (1..4) -%}
          {%- liquid
            if i == 1
              assign current_threshold = threshold_1
              assign current_label = label_1
              assign current_marker_checked = marker_1_checked
            elsif i == 2
              assign current_threshold = threshold_2
              assign current_label = label_2
              assign current_marker_checked = marker_2_checked
            elsif i == 3
              assign current_threshold = threshold_3
              assign current_label = label_3
              assign current_marker_checked = marker_3_checked
            elsif i == 4
              assign current_threshold = threshold_4
              assign current_label = label_4
              assign current_marker_checked = marker_4_checked
            endif
            
            assign is_last = false
            if last_threshold_index == i
              assign is_last = true
            endif
          -%}
          {%- if current_threshold > 0 -%}
          <div class="flex flex-col flex-1 relative {% if is_last %}items-end{% else %}items-center{% endif %} text-12-bold" data-threshold="{{ current_threshold }}" data-label="{{ current_label }}" data-gwp="indicator">
            <div class="text-center">
              <p class="m-0 line-clamp-2 leading-tight min-h-[36px] text-12-bold">
                {{ current_label }}
              </p>
            </div>
            <div class="{% if is_last %}flex flex-col items-end{% endif %}">
              <div class="GWP__marker{% if is_last %} GWP__marker--end{% endif %}{% if current_marker_checked %} GWP__marker--checked{% endif %}" data-gwp="marker"></div>
              <p class="m-0 whitespace-nowrap text-12-bold">{{ current_threshold | money_without_trailing_zeros }}</p>
            </div>
          </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="gwp-progressbar-empty absolute top-[55%] left-0 right-0 h-1 bg-[var(--color-border,#e6e6e6)] rounded-sm -translate-y-1/2 z-[1]"></div>

      <div class="absolute top-[55%] left-0 right-0 h-1 -translate-y-1/2 z-[1] flex overflow-hidden">
        {%- for i in (1..4) -%}
          {%- liquid
            if i == 1
              assign current_threshold = threshold_1
              assign prev_threshold = threshold_0
              assign current_seg_w = seg1_w
            elsif i == 2
              assign current_threshold = threshold_2
              assign prev_threshold = threshold_1
              assign current_seg_w = seg2_w
            elsif i == 3
              assign current_threshold = threshold_3
              assign prev_threshold = threshold_2
              assign current_seg_w = seg3_w
            elsif i == 4
              assign current_threshold = threshold_4
              assign prev_threshold = threshold_3
              assign current_seg_w = seg4_w
            endif
          -%}
          {%- if current_threshold > 0 -%}
          <div class="GWP__segment relative h-full bg-transparent" data-gwp="segment" data-threshold-start="{{ prev_threshold }}" data-threshold-end="{{ current_threshold }}">
            <div class="absolute top-0 left-0 h-full bg-[#C74F1F] transition-[width] duration-500 ease-in-out min-w-0 will-change-[width]" data-gwp="fill" style="width: {{ current_seg_w }}%"></div>
          </div>

          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
    </div>
</div>

{% stylesheet %}
/* Marker styles - specific pixel values and pseudo-elements that can't be done with Tailwind */
.GWP__marker {
  top: -6px;
  position: relative;
  left: 50%;
  height: 17.5px;
  width: 17.5px;
  z-index: 3;
  border: 0.125rem solid #c74f1f;
  border-radius: 3.125rem;
  background-color: #fff;
  transform: translate(-50%);
}

.GWP__marker--start {
  left: 0;
  transform: none;
}

.GWP__marker--end {
  right: 0;
  left: auto;
  transform: none;
}

.GWP__marker--checked {
  background-color: var(--color-brunt-orange);
  border-color: var(--color-brunt-orange);
  top: -6px;
}

.GWP__marker--checked::after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 5px;
  height: 9px;
  border-right: 1.5px solid white;
  border-bottom: 1.5px solid white;
  transform: translate(-50%, -60%) rotate(45deg);
}

.GWP__segment {
  flex: 1;
}

.GWP__segment:first-of-type {
  flex: 1.5;
}

.GWP__segment:last-of-type {
  flex: 1.5;
}

.header-gwp-progressbar {
  background-color: #000;
  color: #fff;
  padding-top: 8px;
  padding-bottom: 8px;
}

.header-gwp-progressbar .GWP__achievedText {
  color: var(--color-white);
}

.header-gwp-progressbar .gwp-progressbar-container {
  max-width: 920px;
  margin-left:auto;
  margin-right:auto;
}

.header-gwp-progressbar svg path {
  fill: var(--color-white);
}

.cart-drawer-gwp-progressbar .cart-gwp-header {
  border-color:var(--color-medium-smoke);
}

.header-gwp-progressbar .gwp-progressbar-empty {
  background-color: var(--color-white);
}
/* .cart-drawer__dialog {
  display: block !important;
  z-index: 99;
} */
{% endstylesheet %}
