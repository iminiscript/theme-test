{%- comment -%}
  Renders the price display for a bundle cart item
  
  @param {string} bundle_ids - Comma-separated variant IDs that make up the bundle
  @param {string} [class] - Additional CSS classes for the price container
{%- endcomment -%}

{%- assign bundle_ids = bundle_ids | split: ',' -%}
{%- assign total_original_price = 0 -%}
{%- assign total_discounted_price = 0 -%}

{%- comment -%} Calculate totals from actual cart items (using line prices to account for quantity) {%- endcomment -%}
{%- for variant_id in bundle_ids -%}
  {%- assign variant_id_trimmed = variant_id | strip -%}
  {%- for cart_item in cart.items -%}
    {%- assign cart_variant_id = cart_item.variant_id | append: '' -%}
    {%- if cart_variant_id == variant_id_trimmed -%}
      {%- assign total_original_price = total_original_price | plus: cart_item.original_line_price -%}
      {%- assign total_discounted_price = total_discounted_price | plus: cart_item.final_line_price -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endfor -%}

<div class="flex flex-row items-end gap-1{% if class %} {{ class }}{% endif %}">
  {%- comment -%} Show discounted price {%- endcomment -%}
  {%- if total_discounted_price > 0 -%}
    {%- liquid
      if settings.currency_code_enabled_cart_items
        assign price_formatted = total_discounted_price | money_with_currency
      else
        assign price_formatted = total_discounted_price | money
      endif
      assign price_parts = price_formatted | split: '.'
      assign integer_part = price_parts[0]
      assign decimal_part = price_parts[1]
    -%}
    
    <text-component class="text-16-bold" value="{{ price_formatted | strip_html }}">
      {{ integer_part }}{% if decimal_part %}<sup>{{ decimal_part }}</sup>{% endif %}
    </text-component>
  {%- endif -%}
  
  {%- comment -%} Show regular price with strikethrough if discount exists {%- endcomment -%}
  {%- if total_original_price > 0 and total_original_price > total_discounted_price -%}
    {%- liquid
      if settings.currency_code_enabled_cart_items
        assign regular_price_formatted = total_original_price | money_with_currency
      else
        assign regular_price_formatted = total_original_price | money
      endif
      assign regular_parts = regular_price_formatted | split: '.'
      assign regular_int = regular_parts[0]
      assign regular_dec = regular_parts[1]
    -%}
    
    <text-component class="text-sm line-through text-gray-400" 
                  value="{{ regular_price_formatted | strip_html }}">
      {{ regular_int }}{% if regular_dec %}<sup>{{ regular_dec }}</sup>{% endif %}
    </text-component>
  {%- endif -%}
</div>
