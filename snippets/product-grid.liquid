{%- doc -%}
  This snippet is used to render the product grid on collection and search pages.

  @param {object} section - The section object (unused, kept for compatibility)
  @param {object} paginate - Pagination object
  @param {object} products - Array of product objects
  @param {string} [title] - Header of the collection or search results
  @param {string} children - List or grid of product cards
  @param {string} no_product_text - The text to display when no products are found
  @param {string} no_product_button_text - The button text for clearing filters
{%- enddoc -%}

<div
  id="ResultsList"
  class="main-collection-grid"
>
  <div>
    {% if products.size == 0 %}
      <div class="flex flex-col items-center justify-center gap-8 py-[120px]">
        <p class="text-18-bold text-asphalt text-center">{{ no_product_text }}</p>
        <a
          class="main-collection-grid__empty-link text-16-regular font-bold uppercase underline text-brunt-orange"
          href="{{ collection.url }}"
        >
          {{ no_product_button_text }}
        </a>
      </div>
    {% else %}
      <span ref="viewMorePrevious"></span>

      {% if title %}
        <h4 class="main-collection-grid__title">{{ title }}</h4>
      {% endif %}
      <ul
        class="product-list-grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-5 lg:gap-x-6 lg:gap-y-10"
        role="list"
        data-last-page="{{ paginate.pages }}"
        ref="grid"
      >
        {{ children }}
      </ul>
      <span ref="viewMoreNext"></span>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .product-list-grid {
    display: grid;
  }

  .main-collection-grid__empty {
    padding-block: var(--padding-6xl);
    padding-inline: var(--page-margin);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--padding-sm);
  }

  .main-collection-grid__empty-title {
    margin: 0;
  }
{% endstylesheet %}
