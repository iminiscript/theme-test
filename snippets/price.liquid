{%- doc -%}
  Renders product pricing with support for price ranges, compare-at prices, and currency formatting.
  
  Displays the current price (or price range if prices vary) and optionally shows the compare-at
  price when the product is on sale. Prices are formatted with currency symbols and split into
  whole dollars and cents (displayed as superscript).

  @param {object} product_resource - The product object containing price information
  @param {boolean} show_price_range - Whether to display price range (min-max) when prices vary (default: false)
  @param {string} price_class - CSS classes for the price element (default: 'text-16-bold')
  @param {string} compare_at_price_class - CSS classes for the compare-at price element (default: 'text-(--color-gray-accessible) text-12-regular line-through')
  @param {string} class - Alternative class parameter (default: 'text-16-bold')

  Output includes data attributes (data-product-id) for JavaScript price updates.
{%- enddoc -%}

{% liquid
  assign show_price_range = show_price_range | default: false
  assign class = class | default: 'text-16-bold'
  assign product_id = product_resource.id | default: blank
  # Price calculations
  assign on_sale_class = blank
  if product_resource.price < product_resource.compare_at_price
    assign on_sale_class = 'text-(--color-brunt-orange)'
  endif
  assign price_varies = product_resource.price_varies | default: false
  if price_varies
    assign price_min_floor = product_resource.price_min | divided_by: 100 | floor | prepend: localization.country.currency.symbol | strip
    assign price_min_sup = product_resource.price_min | modulo: 100
    assign price_min = blank | default: floor: price_min_floor, sup: price_min_sup
    assign price_max_floor = product_resource.price_max | divided_by: 100 | floor | prepend: localization.country.currency.symbol | strip
    assign price_max_sup = product_resource.price_max | modulo: 100
    assign price_max = blank | default: floor: price_max_floor, sup: price_max_sup
  else
    assign price_floor = product_resource.price | divided_by: 100 | floor | prepend: localization.country.currency.symbol | strip
    assign price_sup = product_resource.price | modulo: 100
    assign price = blank | default: floor: price_floor, sup: price_sup
  endif
  # Compare at price - get max compare_at_price if there are multiple
  assign compare_at_price_varies = product_resource.compare_at_price_varies
  if compare_at_price_varies
    assign compare_at_price_min_floor = product_resource.compare_at_price_min | divided_by: 100 | floor | prepend: localization.country.currency.symbol | strip
    assign compare_at_price_min_sup = product_resource.compare_at_price_min | modulo: 100
    assign compare_at_price_min = blank | default: floor: compare_at_price_min_floor, sup: compare_at_price_min_sup
    assign compare_at_price_max_floor = product_resource.compare_at_price_max | divided_by: 100 | floor | prepend: localization.country.currency.symbol | strip
    assign compare_at_price_max_sup = product_resource.compare_at_price_max | modulo: 100
    assign compare_at_price_max = blank | default: floor: compare_at_price_max_floor, sup: compare_at_price_max_sup
  else
    assign compare_at_price_floor = product_resource.compare_at_price | divided_by: 100 | floor | prepend: localization.country.currency.symbol | strip
    assign compare_at_price_sup = product_resource.compare_at_price | modulo: 100
    assign compare_at_price = blank | default: floor: compare_at_price_floor, sup: compare_at_price_sup
  endif
%}

<p class="{{ price_class | default: 'text-16-bold' }} {{ on_sale_class }} priceRange">
  {%- if price_varies and show_price_range -%}
    <span class="igPriceMin" data-product-id="{{ product_resource.id }}">
      {{- price_min.floor -}}
      {%- if price_min.sup > 0 -%}
        <sup class="top-[-0.2em]">{{- price_min.sup -}}</sup>
      {%- endif -%}
    </span>
    -
    <span class="igPriceMax" data-product-id="{{ product_id }}">
      {{- price_max.floor -}}
      {%- if price_max.sup > 0 -%}
        <sup class="top-[-0.2em]">{{- price_max.sup -}}</sup>
      {%- endif -%}
    </span>
  {%- else -%}
    <span class="igPrice" data-product-id="{{ product_id }}">
      {{- price.floor -}}
      {%- if price.sup > 0 -%}
        <sup class="top-[-0.2em]">{{- price.sup -}}</sup>
      {%- endif -%}
    </span>
  {%- endif -%}
</p>
{%- if on_sale_class != blank -%}
  <p class="{{ compare_at_price_class | default: 'text-(--color-gray-accessible) text-12-regular line-through' }} compareAtPrice">
    {%- if compare_at_price_varies and product_resource.compare_at_price_max > product_resource.compare_at_price_min -%}
      <span class="igComparePriceMin" data-product-id="{{ product_id }}">
        {{- compare_at_price_min.floor -}}
        {%- if compare_at_price_min.sup > 0 -%}
          <sup class="top-[-0.3em]">{{- compare_at_price_min.sup -}}</sup>
        {%- endif -%}
      </span>
      -
      <span class="igComparePriceMax" data-product-id="{{ product_id }}">
        {{- compare_at_price_max.floor -}}
        {%- if compare_at_price_max.sup > 0 -%}
          <sup class="top-[-0.3em]">{{- compare_at_price_max.sup -}}</sup>
        {%- endif -%}
      </span>
    {%- else -%}
      <span class="igComparePrice" data-product-id="{{ product_id }}">
        {{- compare_at_price.floor -}}
        {%- if compare_at_price.sup > 0 -%}
          <sup class="top-[-0.3em]">{{- compare_at_price.sup -}}</sup>
        {%- endif -%}
      </span>
    {%- endif -%}
  </p>
{%- endif -%}
