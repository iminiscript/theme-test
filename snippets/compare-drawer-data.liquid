{% comment %}
  Renders compare drawer data as JSON for JavaScript consumption

  Parameters:
  - category: {String} The category name (e.g., "Boots")
  - max_products: {Number} Maximum products to compare
  - compare_categories: {Array} Array of compare category metaobjects
{% endcomment %}

{%- if compare_categories.count > 0 -%}
  {%- capture compare_data -%}
    {
      "category": {{ category | json }},
      "maxProducts": {{ max_products | json }},
      "categories": [
        {%- for compare_category in compare_categories -%}
          {
            "name": {{ compare_category.name.value | json }},
            "products": [
              {%- assign products = compare_category.product_list.value -%}
              {%- for product in products -%}
                {
                  "id": {{ product.id | json }},
                  "title": {{ product.title | json }},
                  "handle": {{ product.handle | json }},
                  "price": {{ product.price | json }},
                  "price_min": {{ product.price_min | json }},
                  "price_max": {{ product.price_max | json }},
                  "compareAtPrice": {{ product.compare_at_price | json }},
                  "url": {{ product.url | json }},
                  "featuredImage": {
                    "src": {{ product.featured_image | image_url: width: 300 | json }},
                    "alt": {{ product.featured_image.alt | json }}
                  },
                  "aggregateRating": {
                    "ratingValue": {{ product.metafields.okendo.summaryData.reviewAverageValue | json }},
                    "reviewCount": {{ product.metafields.okendo.summaryData.reviewCount | json }}
                  },
                  "compare_fields": [
                    {%- for compare_field in product.metafields.custom.comparison_features.value -%}
                      {
                        "key": {{ compare_field.key | json }},
                        {%- if compare_field.copy_value == blank -%}
                          "value": {{ compare_field.truthy_value | default: false }}
                        {%- else -%}
                          "value": {{ compare_field.copy_value | metafield_tag | json }}
                        {%- endif -%}
                      }{%- unless forloop.last -%},{%- endunless -%}
                    {%- endfor -%}
                  ],
                  "variants": [
                    {%- for variant in product.variants -%}
                      {
                        "id": {{ variant.id | json }},
                        "title": {{ variant.title | json }},
                        "price": {{ variant.price | json }},
                        "available": {{ variant.available | json }}
                      }
                      {%- unless forloop.last -%},{%- endunless -%}
                    {%- endfor -%}
                  ]
                }
                {%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          }
          {%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  {%- endcapture -%}

  <script id="compareDrawerData" type="application/json">
    {{ compare_data }}
  </script>
{%- endif -%}
