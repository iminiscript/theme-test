{% comment %}
  Reusable Comparison Chart Component

  Parameters:
  - category: (required) The category name to display (e.g., "Boots", "Apparel")
  - context: (optional) 'page' or 'drawer' - determines if it listens for external events
  - default_product_ids: (optional) Comma-separated string of product IDs to display initially

  Usage:
  {% render 'comparison-chart', category: 'Boots' %}
  {% render 'comparison-chart', category: 'Boots', context: 'page', default_product_ids: '123,456' %}

  Note: The parent container should handle visibility and scrolling classes.
{% endcomment %}

{% liquid
  assign chart_context = context | default: 'drawer'
  assign context_class = ''
  if chart_context == 'page'
    assign context_class = 'external-chart'
  endif
%}

<comparison-chart-component
  class="{{ context_class }}"
  data-category="{{ category }}"
  data-context="{{ chart_context }}"
  data-default-product-ids="{{ default_product_ids }}"
>
  {% comment %} Loading skeleton - only show for page context {% endcomment %}
  {% if chart_context == 'page' %}
    <div ref="comparisonLoader" class="comparison__chartLoader">
      <svg class="comparison__chartLoader-svg" viewBox="0 0 351 507" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect opacity="0.7" width="73" height="123" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" y="147" width="73" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" y="195" width="73" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" y="243" width="73" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" y="291" width="73" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" y="339" width="73" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" y="387" width="73" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" y="435" width="73" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" y="483" width="73" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="89" width="123" height="123" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="89" y="147" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="89" y="195" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="89" y="243" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="89" y="291" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="89" y="339" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="89" y="387" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="89" y="435" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="89" y="483" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="228" width="123" height="123" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="228" y="147" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="228" y="195" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="228" y="243" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="228" y="291" width="123" height="24" rx="4" fill="#F2F2F2"/>
        <rect opacity="0.7" x="228" y="339" width="123" height="24" rx="4" fill="#F2F2F2"/>
