  <div ref="comparisonContent" class="w-full">
    {%- comment -%} Table will be rendered here via JS {%- endcomment -%}
  </div>
</comparison-chart-component>

{% stylesheet %}
  /* Comparison Table Styles */
  /* Alternating row backgrounds starting from 2nd row */
  .comparison-table tbody tr:nth-child(even) {
    background-color: #f2f2f2;
  }

  .comparison-table .metafield-rich_text_field p {
    font-size: 14px;
  }

  .external-chart .comparison-table th:first-child {
    padding-left: 12px;
  }

  .external-chart .comparison-table td:last-child {
    padding-right: 12px;
  }

  @media (min-width: 448px) {
    .external-chart .comparison-table th:first-child {
      padding-left: 32px;
    }

    .external-chart .comparison-table td:last-child {
      padding-right: 32px;
    }
  }

  @media (min-width: 768px) {
    .external-chart .comparison-table th:first-child {
      padding-left: 48px;
    }

    .external-chart .comparison-table td:last-child {
      padding-right: 48px;
    }
  }

  .external-chart .comparison-table td a {
    max-width: 160px;
    margin: 12px auto 0 auto;
  }

  /* Loading skeleton styles */
  .comparison__chartLoader {
    max-width: 90rem; /* 1440px */
    width: 100%;
    display: block;
  }

  .comparison__chartLoader-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (min-width: 768px) {
    .comparison__chartLoader {
      padding: 14px 0;
      margin: 0 auto;
    }
  }

  /* Hide loader when chart is loaded */
  .comparison__chartLoader.hidden {
    display: none;
  }
{% endstylesheet %}

<script
  src="{{ 'comparison-chart.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>
