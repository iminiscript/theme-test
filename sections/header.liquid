{% liquid
  assign _section = section.settings
  assign logo = settings.logo
%}

<navigation-component>
  <header-component
    id="header-component"
    class="bg-white  block"
    role="banner"
  >
    <div class="grid grid-cols-[1.5fr_2fr_1.5fr] items-center md:px-5 px-3 py-3">
      <nav class="" aria-label="Primary navigation">
        <div class="lg:hidden">
          <ul class="flex gap-4">
            <li>
              <button class="js-nav__toggle cursor-pointer" aria-label="Open menu" aria-expanded="false" aria-controls="header-navigation-id">
                <span class="icon--menu">
                  {% render 'icon', icon: 'hamburger', class: 'h-5 w-5 md:h-6 md:w-6' %}
                </span>
                <span class="icon--menuClose" style="display: none;">
                  {% render 'icon', icon: 'close', class: 'h-5 w-5 md:h-6 md:w-6' %}
                </span>
              </button>
            </li>
            <li>
              <button class="cursor-pointer" aria-label="Search">
                {% render 'icon', icon: 'search-nav', class: 'h-5 w-5 md:h-6 md:w-6' %}
              </button>
            </li>
          </ul>
        </div>

        <div
          id="header-navigation-id"
          class="header__navigation js-header__navigation w-full absolute top-full pb-20 h-screen overflow-scroll -translate-x-[calc(100%+20px)] [&[aria-hidden='false']]:-translate-x-[12px] md:[&[aria-hidden='false']]:-translate-x-[20px] transition-transform duration-300 ease-in-out bg-white lg:relative lg:h-auto lg:pb-0 lg:translate-x-0 lg:overflow-visible lg:z-[1] lg:bg-transparent"
          aria-hidden="true"
        >
          <div class="header__navDrawer header__navDrawer--mobile relative h-full overflow-y-scroll lg:flex lg:static lg:overflow-y-visible lg:gap-8 lg:items-center">
            {% content_for 'blocks' %}
            <div class="header__storeLocatorClose relative z-20">
              {%- if _section.enable_store_locator -%}
                <a
                  href="{{ _section.store_locator_link }}"
                  class="header__storeLocator text-14-bold-caps no-underline text-asphalt hidden lg:block"
                >
                  STORE LOCATOR
                </a>
              {%- endif -%}
              <button class="header__closeNav hidden absolute top-0 -right-[10px] w-[calc(100%+16px)] h-full z-[1] bg-white -mt-[20px] pt-[21px] pr-4 pb-[40px] pl-0 [&_svg]:block [&_svg]:ml-auto">
                {% render 'icons', icon: 'close' %}
              </button>
            </div>
            {%- assign disable_chat = _section.chat -%}
            {%- assign disable_email = _section.email -%}
            {%- assign disable_call_us = _section.call_us -%}
            {% render 'navigation-contact',
              _section: _section,
              disable_chat: disable_chat,
              disable_email: disable_email,
              disable_call_us: disable_call_us
            %}
          </div>
        </div>
      </nav>

      <div class="text-center">
        <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}" class="inline-block no-underline text-asphalt align-bottom">
          {% if logo != blank %}
            <img
              src="{{ logo | image_url: width: 100 }}"
              alt="{{ shop.name }}"
              width="{{ logo.width }}"
              height="{{ logo.height }}"
              class="max-h-[37px] lg:max-h-[45px] overflow-hidden max-w-full"
            >
          {% else %}
            <span class="text-14-bold-caps">{{ shop.name }}</span>
          {% endif %}
        </a>
      </div>

      <div aria-label="Utility navigation">
        <ul class="flex justify-end gap-4">
          <li class="hidden lg:block">
            <button class="cursor-pointer" aria-label="Search">
              {% render 'icon', icon: 'search-nav', class: 'h-5 w-5 md:h-6 md:w-6' %}
            </button>
          </li>
          <li>
            <button class="cursor-pointer" aria-label="My account">
              {% render 'icon', icon: 'account', class: 'h-5 w-5 md:h-6 md:w-6' %}
            </button>
          </li>
          <li>
            {% render 'cart-drawer' %}
          </li>
        </ul>
      </div>
    </div>
    <div
      class="sidebarMenu__drawerOverlay hidden lg:block fixed top-0 left-0 w-screen h-screen bg-black opacity-30 invisible transition-[visibility_0.2s_ease-in-out] z-0 cursor-pointer [&.is--active]:visible"
    ></div>
    {%- comment -%} Cart Progress Bar / GWP Progress Bar {%- endcomment -%}
    {%- liquid
      assign show_gwp = false
      assign is_usd = false
      if cart.currency.iso_code == 'USD'
        assign is_usd = true
      endif

      comment
        Show if: (USD and enable_global_bar) OR (INT and enable_promo_bar_int) OR (both enabled)
        AND cart is not empty
      endcomment
      if cart.item_count > 0
        if is_usd and settings.enable_global_bar
          assign show_gwp = true
        elsif is_usd == false and settings.enable_promo_bar_int
          assign show_gwp = true
        elsif settings.enable_global_bar and settings.enable_promo_bar_int
          assign show_gwp = true
        endif
      endif
    -%}

    {%- if show_gwp -%}
      {% render 'gwp-progressbar', section_id: section.id, class: 'header-gwp-progressbar' %}
    {%- endif -%}
  </header-component>
</navigation-component>

<script src="{{ 'header.js' | asset_url }}" type="module" fetchpriority="high"></script>
<script src="{{ 'navigation.js' | asset_url }}" type="module" fetchpriority="high"></script>

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "settings": [
    {
      "type": "header",
      "content": "t:content.logo"
    },
    {
      "type": "paragraph",
      "content": "t:content.edit_logo_in_theme_settings"
    },

    {
      "type": "header",
      "content": "Store Locator"
    },
    {
      "type": "checkbox",
      "id": "enable_store_locator",
      "label": "Enable Store Locator",
      "info": "Enable and show store locator link on desktop Nav links",
      "default": true
    },
    {
      "type": "url",
      "id": "store_locator_link",
      "label": "Store Locator Link",
      "visible_if": "{{ section.settings.enable_store_locator == true }}"
    },

    {
      "type": "header",
      "content": "Contact Options"
    },
    {
      "type": "checkbox",
      "id": "call_us",
      "label": "Hide Call Us",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "email",
      "label": "Hide Email Us",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "chat",
      "label": "Hide Chat With Us",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "_navigation"
    }
  ],
  "presets": [
    {
      "name": "Header",
      "category": "t:categories.header"
    }
  ]
}
{% endschema %}
