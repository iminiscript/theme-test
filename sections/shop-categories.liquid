<div class="px-3 md:px-8 lg:px-12 py-12 md:py-16">
  <div class="container-content flex flex-col gap-5 md:gap-8">
    {% if section.settings.heading != blank %}
      <h3 class="text-heading-4 text-center">
        {{ section.settings.heading }}
      </h3>
    {% endif %}

    <div class="mx-auto grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="col-span-1 no-underline text-asphalt hover:text-brunt-orange" aria-label="Shop {{ block.settings.title }}">
          <div class="max-w-[280px] max-h-[280px] md:max-w-[235px] md:max-h-[235px] mb-2">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 500 | image_tag: loading: 'lazy', class: 'shoppable-category__image', widths: '165, 335', alt: block.settings.title }}
            {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'shoppable-category__image shoppable-category__image--placeholder' }}
            {% endif %}
          </div>
          <div class="flex items-center gap-1">
            <span class="text-18-regular">{{ block.settings.title }}</span>
            {% render 'icon', icon: 'arrow-top-right' %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Shop Categories",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop BRUNT"
    }
  ],
  "presets": [
    {
      "name": "Shop Categories",
      "category": "t:categories.storytelling",
      "settings": {
        "heading": "Shop BRUNT"
      },
      "blocks": [
        {
          "type": "category",
          "settings": {
            "title": "Boots"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Apparel"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "Accessories"
          }
        },
        {
          "type": "category",
          "settings": {
            "title": "BRUNT Merch"
          }
        }
      ]
    }
  ]
}
{% endschema %}

