<div class="order-tracking-section px-3 md:px-8 lg:px-12">
  <div class="container-layout">
    <div class="order-tracking-header text-center pb-6 pt-8 md:pt-16 md:pb-12" data-state="header">
      <h1 class="text-heading-2">
        {{ section.settings.heading }}
      </h1>
      <p class="text-16-regular">
        {{ section.settings.subheading }}
      </p>
    </div>
    <div class="order-tracking-form max-w-[720px] mx-auto pt-5 pb-12 md:pb-16" data-state="form">
      <form id="order-tracking-form" method="post" action="javascript:void(0);">
        <div class="form-group mb-4">
          <label for="order-number" class="block text-14-bold mb-1">
            Order Number
          </label>
          <input
            type="text"
            id="order-number"
            name="order_number"
            class="w-full p-4 max-h-[52px] text-14-light mb-1 border border-medium-asphalt focus:border-asphalt focus:outline-none appearance-none rounded-none"
            placeholder=""
            autocomplete="off"
          />
          <p class="text-12-light">
            Find this number from the confirmation email (e.g., #1234567)
          </p>
        </div>

        <div class="form-group mb-5 md:mb-8">
          <label for="email-address" class="block text-14-bold mb-1">
            Email Address
          </label>
          <input
            type="email"
            id="email-address"
            name="email"
            class="w-full p-4 max-h-[52px] text-14-light border border-medium-asphalt focus:border-asphalt focus:outline-none appearance-none rounded-none"
            placeholder=""
            autocomplete="email"
          />
        </div>

        {%- comment -%} OR Divider {%- endcomment -%}
        <div class="flex items-center mb-5 md:mb-8">
          <div class="flex-1 border-t border-medium-smoke"></div>
          <span class="px-4 text-16-bold-caps">or</span>
          <div class="flex-1 border-t border-medium-smoke"></div>
        </div>

        {%- comment -%} Tracking Number Field {%- endcomment -%}
        <div class="form-group mb-5 md:mb-8">
          <label for="tracking-number" class="block text-14-bold mb-1">
            Tracking Number
          </label>
          <input
            type="text"
            id="tracking-number"
            name="tracking_number"
            class="w-full p-4 max-h-[52px] text-14-light mb-1 border border-medium-asphalt focus:border-asphalt focus:outline-none appearance-none rounded-none"
            placeholder=""
            autocomplete="off"
          />
          <p class="text-12-light">
            Carrier's Shipment ID (e.g., 1Z...)
          </p>
        </div>

        {%- comment -%} Error Message {%- endcomment -%}
        <div id="tracking-error" class="hidden bg-gentle-pink py-2.5 px-3 text-cherry tracking-error-animate mb-5 md:mb-8">
          <p class="text-14-regular"></p>
        </div>

        {%- comment -%} Submit Button {%- endcomment -%}
        <div class="text-center">
          {% render 'button',
              label: 'Track Your Order',
              type: "submit",
              style: 'primary',
              color: 'orange',
              size: 'medium',
              width_small: 'fill',
              width_medium: 'custom',
              custom_width_medium: 320
          %}
        </div>
      </form>
    </div>
    <div id="order-status-view" class="hidden container-content pt-5 pb-10 md:pb-6 md:pt-6 lg:pt-8 lg:pb-8 mx-auto transition-all duration-300 ease-in-out order-status-animate">
      <div class="order-status-header mb-5">
        <p class="text-16-bold mb-2" id="order-number-display"></p>
        <h2 class="text-heading-2 mb-1" id="status-title"></h2>
        <p class="text-20-light" id="status-description"></p>
      </div>

      {%- comment -%} Status Timeline {%- endcomment -%}
      <div class="status-timeline mb-2 md:mb-5">
        {% render 'order-status-timeline' %}
      </div>

      {%- comment -%} Track Package Button (for in-transit and out-for-delivery) {%- endcomment -%}
      <div id="track-package-button" class="hidden w-full md:w-1/2 lg:w-1/4 lg:max-w-[240px] mt-6 md:mt-4 ml-auto">
        {% render 'button',
          label: 'Track Your Package',
          url: '#',
          target: true,
          style: 'primary',
          color: 'asphalt',
          size: 'small',
          width_small: 'fill',
          width_medium: 'fill',
          width_large: 'fill',
          icon_right: 'chevron-right'
        %}
      </div>

      {%- comment -%} Delivered Action Buttons {%- endcomment -%}
      <div id="delivered-actions" class="flex flex-col md:flex-row gap-3 mt-6 md:mt-4 justify-right">
        <div class="w-full md:w-1/2 lg:w-1/4 lg:max-w-[240px]">
          {% render 'button',
            label: 'Start a return or exchange',
            url: '/pages/returns-exchanges',
            style: 'primary',
            color: 'asphalt',
            size: 'small',
            width_small: 'fill',
            width_medium: 'fill',
            width_large: 'fill'
          %}
        </div>
      </div>
    </div>

    <div id="shipping-details-panel" class="hidden container-content pt-6 pb-8 md:pb-12 md:pt-12 lg:pt-16 lg:pb-16">
      {% render 'shipping-details-panel' %}
    </div>
  </div>
</div>

<script src="{{ 'order-tracking.js' | asset_url }}" defer></script>

<style>
  /* Collapsed State - Hide Events 4+ */
  .tracking-events[data-collapsed="true"] .tracking-event:nth-child(3) {
    margin-bottom: 0;
  }
  .tracking-events[data-collapsed="true"] .tracking-event:nth-child(n + 4) {
    display: none;
  }
  .show-more-button[data-expanded="true"] [data-show-more-icon] {
    transform: rotate(180deg);
  }
</style>

  {% schema %}
{
  "name": "Order Tracking",
  "tag": "section",
  "class": "section-order-tracking",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Track Your Order"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Track your order status with the order number or tracking number."
    }
  ],
  "presets": [
    {
      "name": "Order Tracking"
    }
  ]
}
{% endschema %}

