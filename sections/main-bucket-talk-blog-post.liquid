{%- liquid
  assign article_image = article.image
  assign article_title = article.title
  assign article_author = article.author
  assign article_date = article.published_at | date: "%B %d, %Y"
  assign article_content = article.content
  
  # Podcast metafields (these would be set in Shopify admin)
  assign podcast_duration_minutes = article.metafields.custom.podcast_duration | default: 35
  assign podcast_duration_minutes = podcast_duration_minutes | plus: 0
  
  # Calculate hours and minutes
  if podcast_duration_minutes >= 60
    assign hours = podcast_duration_minutes | divided_by: 60
    assign minutes = podcast_duration_minutes | modulo: 60
    
    if hours == 1
      assign hours_text = "1 hour"
    else
      assign hours_text = hours | append: " hours"
    endif
    
    if minutes == 0
      assign podcast_duration = hours_text
    elsif minutes == 1
      assign podcast_duration = hours_text | append: " 1 minute"
    else
      assign minutes_text = minutes | append: " minutes"
      assign podcast_duration = hours_text | append: " " | append: minutes_text
    endif
  else
    if podcast_duration_minutes == 1
      assign podcast_duration = "1 minute"
    else
      assign podcast_duration = podcast_duration_minutes | append: " minutes"
    endif
  endif
  assign spotify_url = article.metafields.custom.spotify_url
  assign apple_podcasts_url = article.metafields.custom.apple_podcasts_url
  assign youtube_url = article.metafields.custom.youtube_url
  assign transcript_content = article.metafields.custom.transcript_content
  assign spotify_embed_iframe = article.metafields.custom.spotify_embed_iframe
  assign youtube_video_id = article.metafields.custom.youtube_video_id
-%}

<div class="bg-white pt-3 pb-10 px-3 md:pb-16 md:px-8 lg:px-12">
  <div class="container-content mx-auto">
    {%- comment -%} Hero Section - Split Layout {%- endcomment -%}
    <div class="flex flex-col md:flex-row gap-0 mb-8">
      {%- comment -%} Left: Podcast Image {%- endcomment -%}
      {%- if article_image -%}
        <div class="aspect-square w-full md:w-1/2 md:h-1/2 md:max-w-[500px] mx-auto">
          {{ article_image | image_url: width: 500 | image_tag:
              width: article_image.width,
              widths: '351, 500',
              height: article_image.height,
              class: 'w-full h-full object-cover',
              loading: 'eager',
              fetchpriority: 'high',
              alt: article_image.alt
          }}
        </div>
      {%- endif -%}
      
      {%- comment -%} Right: Dark Info Box {%- endcomment -%}
      <div class="bg-asphalt pt-4 px-4 pb-5 lg:pt-6 lg:px-6 lg:pb-7 flex flex-col justify-between w-full md:w-1/2 md:max-w-[500px] mx-auto">
        <div class="flex flex-col mb-3">
          {%- comment -%} Date and Duration {%- endcomment -%}
          <div class="text-white text-12-regular mb-3">
            {{ article_date }} | {{ podcast_duration }}
          </div>
          
          {%- comment -%} Title {%- endcomment -%}
          <h1 class="text-white text-sh24 font-interstate mb-2">{{ article_title }}</h1>
          
          {%- comment -%} Description {%- endcomment -%}
          <p class="text-white text-16-light overflow-hidden">
            {%- if article.excerpt != blank -%}
              <span class="block overflow-hidden md:line-clamp-6 mid:line-clamp-9 lg:line-clamp-12">{{ article.excerpt }}</span>
            {%- endif -%}
          </p>
        </div>
        
        {%- comment -%} Listen On Section {%- endcomment -%}
        <div class="flex flex-col gap-4 pt-4">
          <p class="text-white text-14-bold-caps">Listen on</p>
          <div class="flex gap-6 items-center">
            {%- if apple_podcasts_url -%}
              <a href="{{ apple_podcasts_url }}" target="_blank" rel="noopener noreferrer" aria-label="Listen on Apple Podcasts" class="">
                {% render 'icons', icon: 'apple-podcasts' %}
              </a>
            {%- endif -%}
            
            {%- if spotify_url -%}
              <a href="{{ spotify_url }}" target="_blank" rel="noopener noreferrer" aria-label="Listen on Spotify" class="">
                {% render 'icons', icon: 'spotify-podcasts' %}
              </a>
            {%- endif -%}
            
            {%- if youtube_url -%}
              <a href="{{ youtube_url }}" target="_blank" rel="noopener noreferrer" aria-label="Watch on YouTube" class="">
                {% render 'icons', icon: 'youtube-podcasts' %}
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
    
    {%- comment -%} Main Content {%- endcomment -%}
    <div class="my-8">
      <div class="bucket-talk-content text-asphalt">
        {{ article_content }}
      </div>
    </div>

    {% comment %} Spotify Embed Section {% endcomment %}
    {%- if spotify_embed_iframe -%}
      <div class="my-2">
        {{ spotify_embed_iframe }}
      </div>
    {%- endif -%}

    {%- comment -%} Transcript Section {%- endcomment -%}
    {%- if transcript_content -%}
      <div class="pb-6">
        <details class="relative bg-light-smoke group py-2 px-3 lg:py-3 lg:px-6 max-h-[640px] overflow-hidden">
          <summary class="flex gap-1 cursor-pointer py-3">
            <span class="text-asphalt text-14-bold-caps">View Transcript</span>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="transition-transform duration-200 group-open:rotate-180">
              <path d="M4.5 6.75L9 11.25L13.5 6.75" stroke="#1E1B1C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <div class="bucket-talk-scroll overflow-y-auto max-h-[560px] mt-3">
            <div class="text-asphalt text-16-light leading-[22px]">
              {{ transcript_content | metafield_tag }}
            </div>
          </div>
        </details>
      </div>
    {%- endif -%}
    
    {%- comment -%} Video Section {%- endcomment -%}
    {% if youtube_video_id != blank %}
      <div class="relative aspect-video js-video__container  bg-asphalt">
        <button
          tabindex="0"
          class="absolute inset-0 js-video__trigger cursor-pointer w-full h-full border-0 p-0 bg-transparent focus-visible:outline-2 focus-visible:outline-brunt-orange"
          aria-label="Play video{% if article_title != blank %}: {{ article_title }}{% endif %}"
          type="button"
        >
          {%- assign youtube_thumbnail_url = 'https://i.ytimg.com/vi/'
            | append: youtube_video_id
            | append: '/maxresdefault.jpg'
          -%}
          <img
            src="{{ youtube_thumbnail_url }}"
            alt="Video thumbnail{% if article_title != blank %} for {{ article_title }}{% endif %}"
            class="w-full h-full object-cover block"
            onerror="this.onerror=null; this.src='https://i.ytimg.com/vi/{{ youtube_video_id }}/hqdefault.jpg';"
          >
          <div
            class="absolute inset-0 flex items-center justify-center transition-all duration-300 pointer-events-none"
            aria-hidden="true"
          >
            <div class="transform group-hover:scale-110 group-focus-visible:scale-110 transition-all duration-300">
              {% render 'icon', icon: 'video' %}
            </div>
          </div>
        </button>

        {% assign player_id = section.id | append: '-player' %}
        <div
          class="absolute inset-0 hidden js-video__iframe"
          data-video-id="{{ youtube_video_id }}"
          data-player-id="{{ player_id }}"
        >
          <div id="{{ player_id }}" class="w-full h-full"></div>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{{ 'media-content.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Bucket Talk Blog Post",
  "class": "section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Podcast Settings"
    },
    {
      "type": "paragraph",
      "content": "Configure podcast links and content using article metafields in Shopify admin."
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "presets": []
}
{% endschema %}
