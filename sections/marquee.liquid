{%- liquid
  assign bg_color = section.settings.background_color | default: 'bg-white'
  assign text_color = section.settings.text_color | default: 'text-asphalt'
  assign movement_direction = section.settings.movement_direction | default: 'normal'
  assign speed = section.settings.speed
-%}

<div
  id="marquee-section-{{ section.id }}"
  class="overflow-hidden py-[13px] h-[48px] {{ bg_color }}"
  role="region"
  aria-label="Marquee Section"
>
  {% if section.blocks.size > 0 %}
    <div class="relative flex w-full max-w-[1440px] mx-auto overflow-hidden">
      <div class="marquee-content-wrapper flex w-full">
        {% for i in (1..5) %}
          <ul class="marquee-content flex list-none m-0 p-0 flex-shrink-0 gap-0 {% if speed > 0 %}animate-marquee{% endif %}" {% if i > 1 %}aria-hidden="true"{% endif %}>
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'text' %}
                  <li class="flex items-center" {{ block.shopify_attributes }}>
                    <span class="text-14-bold-caps uppercase {{ text_color }}">
                      {{ block.settings.value_prop }}
                    </span>
                    <span class="w-1.5 h-1.5 inline-block mx-10 rotate-45 {{ text_color | replace: 'text', 'bg' }}"></span>
                  </li>
              {% endcase %}
            {% endfor %}
          </ul>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

{% style %}
  @media (min-width:1430px) {
    {% comment %} Apply fade mask to content wrapper for smooth edge fade {% endcomment %}
    #shopify-section-{{ section.id }} .marquee-content-wrapper {
      mask-image: linear-gradient(
        to right,
        transparent 0,
        black 64px,
        black calc(100% - 64px),
        transparent 100%
      );
      -webkit-mask-image: linear-gradient(
        to right,
        transparent 0,
        black 64px,
        black calc(100% - 64px),
        transparent 100%
      );
    }
  }
{% endstyle %}

{% if speed > 0 %}
  <script>
    (function () {
      const marqueeSection = document.querySelector('#marquee-section-{{ section.id }}');
      if (!marqueeSection) return;

      const marqueeContent = marqueeSection.querySelector('.marquee-content');
      if (!marqueeContent) return;

      // Define consistent speed in pixels per second
      const SPEED_PX_PER_SECOND = {{ speed }};

      function setMarqueeSpeed() {
        // Get the width of one marquee content set
        const contentWidth = marqueeContent.offsetWidth;

        // Calculate duration based on width and desired speed
        // duration = distance / speed
        const duration = contentWidth / SPEED_PX_PER_SECOND;

        // Get all marquee content elements
        const allMarqueeContent = marqueeSection.querySelectorAll('.marquee-content');
        for (const content of allMarqueeContent) {
          content.style.animation = `marquee-scroll ${duration}s linear infinite {{ movement_direction }}`;
        }
      }

      // Set speed on load
      setMarqueeSpeed();

      // Recalculate on window resize
      let resizeTimeout;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(setMarqueeSpeed, 250);
      });
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "t:names.marquee",
  "disabled_on": {
    "groups": ["header"]
  },
  "blocks": [
    {
      "name": "Value Prop",
      "type": "text",
      "settings": [
        {
          "type": "text",
          "id": "value_prop",
          "label": "Text",
          "info": "Enter text for the auto-scrolling value propositions"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "movement_direction",
      "label": "t:settings.motion_direction",
      "options": [
        {
          "value": "normal",
          "label": "To Left"
        },
        {
          "value": "reverse",
          "label": "To Right"
        }
      ],
      "default": "normal"
    },
    {
      "type": "number",
      "id": "speed",
      "label": "Speed",
      "default": 50,
      "info": "pixels per second (default: 50)"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": [
        { "value": "bg-white", "label": "White" },
        { "value": "bg-light-smoke", "label": "Light Smoke" },
        { "value": "bg-medium-smoke", "label": "Medium Smoke" },
        { "value": "bg-asphalt", "label": "Asphalt" }
      ],
      "default": "bg-white"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text Color",
      "options": [
        { "value": "text-black fill-black", "label": "Black" },
        { "value": "text-asphalt fill-asphalt", "label": "Asphalt" },
        { "value": "text-medium-smoke fill-medium-smoke", "label": "Medium Smoke" },
        { "value": "text-light-smoke fill-light-smoke", "label": "Light Smoke" },
        { "value": "text-white fill-white", "label": "White" }
      ],
      "default": "text-asphalt fill-asphalt"
    }
  ],
  "presets": [
    {
      "name": "t:names.marquee_section",
      "category": "t:categories.banners",
      "blocks": [
        {
          "type": "text",
          "settings": {
            "value_prop": "Try Risk-Free On The Job"
          }
        },
        {
          "type": "text",
          "settings": {
            "value_prop": "Free Shipping & Exchanges"
          }
        },
        {
          "type": "text",
          "settings": {
            "value_prop": "Designed By Workers"
          }
        },
        {
          "type": "text",
          "settings": {
            "value_prop": "All-Day Comfort"
          }
        },
        {
          "type": "text",
          "settings": {
            "value_prop": "Durable"
          }
        }
      ]
    }
  ]
}
{% endschema %}
