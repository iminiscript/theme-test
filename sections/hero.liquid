{% liquid
  assign autoplay_enabled = section.settings.autoplay
  assign autoplay_delay = section.settings.autoplay_delay | times: 1000
  assign transition_speed = section.settings.transition_speed
  assign vertical_position = section.settings.vertical_position
  assign horizontal_position = section.settings.horizontal_position
  assign config_id = section.id | replace: '-', '_' | replace: '--', '_'
%}

<div id="Hero-{{ section.id }}" class="hero-carousel-wrapper relative w-full h-[447px] md:h-[798px] lg:h-[750px] overflow-hidden">
  <div
    class="swiper__carousel w-full h-full"
    data-config="heroConfig_{{ config_id }}"
  >
    <div class="swiper-wrapper">
      {% content_for 'blocks' %}
    </div>

    <div class="mx-auto max-w-[1440px] px-3 md:px-8 lg:px-12 relative">
      {% comment %} Pagination - Outside slides so it appears on all slides {% endcomment %}
      {% if section.blocks.size > 1 %}
        <div class="absolute bottom-3 md:bottom-8 lg:bottom-12  {% if horizontal_position == 'right' %}right-1/2 lg:right-12 translate-x-1/2{% else %}left-1/2 lg:left-12 -translate-x-1/2{% endif %} lg:translate-0 z-20">
          <div class="hero-carousel__pagination flex gap-2 items-center"></div>
        </div>
      {% endif %}

      {% comment %} Navigation Arrows - Outside slides {% endcomment %}
      {% if section.blocks.size > 1 %}
        <div class="hero-carousel__navigation absolute bottom-3 md:bottom-8 lg:bottom-12 {% if horizontal_position == 'right' %}left-3 md:left-8 lg:left-12{% else %}right-3 md:right-8 lg:right-12{% endif %} z-20 hidden lg:flex gap-4">
          <button
            class="hero-carousel__button-prev w-12 h-12 rounded-full bg-white border border-[#1e1b1c] flex items-center justify-center hover:bg-gray-100 hover:scale-105 active:scale-95 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#c74f1f]"
            aria-label="{{ 'sections.hero.previous_slide' | t | default: 'Previous slide' }}"
          >
            {% render 'icon', icon: 'pointer-arrow-left' %}
          </button>

          <button
            class="hero-carousel__button-next w-12 h-12 rounded-full bg-white border border-[#1e1b1c] flex items-center justify-center hover:bg-gray-100 hover:scale-105 active:scale-95 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#c74f1f]"
            aria-label="{{ 'sections.hero.next_slide' | t | default: 'Next slide' }}"
          >
            {% render 'icon', icon: 'pointer-arrow-right' %}
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  // Hero Carousel Configuration for section {{ section.id }}
  window.heroConfig_{{ config_id }} = {
    slidesPerView: 1,
    spaceBetween: 0,
    loop: true,
    speed: {{ transition_speed }},
    resizeObserver: false, // Disable resize observer since we're always 100vw
    observer: true, // Enable observer for dynamic content
    observeParents: true,
    effect: "fade",
    fadeEffect: {
      crossFade: true,
    },
    autoplay: {{ autoplay_enabled }} ? {
      delay: {{ autoplay_delay }},
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    } : false,
    pagination: {
      el: "#Hero-{{ section.id }} .hero-carousel__pagination",
      clickable: true,
      renderBullet: function (index, className) {
        return `<span class="${className}" role="button" aria-label="Go to slide ${index + 1}">
          <span class="hero-carousel__progress-bar"></span>
        </span>`;
      },
    },
    navigation: {
      nextEl: "#Hero-{{ section.id }} .hero-carousel__button-next",
      prevEl: "#Hero-{{ section.id }} .hero-carousel__button-prev",
    },
    keyboard: {
      enabled: true,
      onlyInViewport: true,
    },
    a11y: {
      prevSlideMessage: "Previous slide",
      nextSlideMessage: "Next slide",
      paginationBulletMessage: "Go to slide {{index}}",
    },
    on: {
      init: function() {
        handleVideoPlayback_{{ config_id }}(this);
        adjustAutoplayDelay_{{ config_id }}(this);
      },
      slideChange: function() {
        handleVideoPlayback_{{ config_id }}(this);
        adjustAutoplayDelay_{{ config_id }}(this);
      },
      autoplayTimeLeft: function(swiper, time, progress) {
        if (typeof window.updateProgressBar === 'function') {
          window.updateProgressBar(
            swiper,
            progress,
            ".hero-carousel-wrapper",
            ".hero-carousel__pagination",
            ".hero-carousel__progress-bar"
          );
        }
      },
    },
  };

  // Helper functions for hero carousel - scoped to this section
  let videoPlaybackTimeout_{{ config_id }} = null;
  const videoPendingPromises_{{ config_id }} = new WeakMap();
  
  function handleVideoPlayback_{{ config_id }}(swiper) {
    // Debounce rapid calls during transitions
    if (videoPlaybackTimeout_{{ config_id }}) {
      clearTimeout(videoPlaybackTimeout_{{ config_id }});
    }
    
    videoPlaybackTimeout_{{ config_id }} = setTimeout(() => {
      performVideoPlayback_{{ config_id }}(swiper);
    }, 50); // Small delay to batch rapid transition events
  }
  
  async function performVideoPlayback_{{ config_id }}(swiper) {
    const currentActiveIndex = swiper.activeIndex;
    const activeSlide = swiper.slides[currentActiveIndex];
    
    if (!activeSlide) return;

    // Get active videos first
    const activeVideos = Array.from(activeSlide.querySelectorAll("video"));
    const allVideos = swiper.el.querySelectorAll("video");
    
    // Wait for any pending play promises to resolve before pausing
    const pausePromises = [];
    
    allVideos.forEach(video => {
      // Skip videos in the active slide
      if (activeVideos.includes(video)) return;
      
      // If there's a pending play promise, wait for it
      const pendingPromise = videoPendingPromises_{{ config_id }}.get(video);
      if (pendingPromise) {
        pausePromises.push(
          pendingPromise.catch(() => {}).then(() => {
            video.pause();
            video.currentTime = 0;
            videoPendingPromises_{{ config_id }}.delete(video);
          })
        );
      } else {
        // No pending promise, pause immediately
        video.pause();
        video.currentTime = 0;
      }
    });
    
    // Wait for all pauses to complete
    if (pausePromises.length > 0) {
      await Promise.all(pausePromises);
    }

    // Now play active videos
    activeVideos.forEach(video => {
      // Reset to start
      video.currentTime = 0;
      
      // Attempt to play
      const playPromise = video.play();
      
      if (playPromise !== undefined) {
        // Store the promise
        videoPendingPromises_{{ config_id }}.set(video, playPromise);
        
        playPromise
          .then(() => {
            // Successfully playing, remove from pending
            videoPendingPromises_{{ config_id }}.delete(video);
          })
          .catch(error => {
            // Remove from pending on error
            videoPendingPromises_{{ config_id }}.delete(video);
            
            // Silently handle expected errors
            const expectedErrors = ['NotAllowedError', 'NotSupportedError', 'AbortError'];
            if (!expectedErrors.includes(error.name)) {
              console.warn("Video playback error:", error.name, error.message);
            }
          });
      }
    });
  }

  function adjustAutoplayDelay_{{ config_id }}(swiper) {
    if (!swiper || !swiper.autoplay) return;

    const activeSlide = swiper.slides[swiper.activeIndex];
    if (!activeSlide) return;

    const slideDelayOverride = parseInt(activeSlide.dataset.slideDelay) || 0;
    const defaultDelay = {{ autoplay_delay }};
    const delay = slideDelayOverride > 0 ? slideDelayOverride * 1000 : defaultDelay;

    if (swiper.params.autoplay.delay !== delay) {
      swiper.params.autoplay.delay = delay;

      if (swiper.autoplay.running) {
        swiper.autoplay.stop();
        swiper.autoplay.start();
      }
    }
  }

  // Setup visibility handling for autoplay
  document.addEventListener("visibilitychange", () => {
    const config = window.heroConfig_{{ config_id }};
    if (config && config.$swiper) {
      if (document.hidden) {
        config.$swiper.autoplay?.stop();
      } else {
        config.$swiper.autoplay?.start();
      }
    }
  });

  // Initialize this carousel after config is defined
  if (typeof window.initCarousel === 'function') {
    const element = document.querySelector('[data-config="heroConfig_{{ config_id }}"]');
    if (element && !element.classList.contains('swiper-initialized')) {
      window.initCarousel(element);
    }
  } else {
    // If carousel.js hasn't loaded yet, wait for it
    document.addEventListener('DOMContentLoaded', () => {
      const element = document.querySelector('[data-config="heroConfig_{{ config_id }}"]');
      if (element && !element.classList.contains('swiper-initialized')) {
        import('{{ 'carousel.js' | asset_url }}').then(module => {
          module.initCarousel(element);
        });
      }
    });
  }
</script>

<style>
  @layer components {
      /* Progress Bar Animation */
      .hero-carousel__progress-bar {
          animation: hero-progress linear;
      }

      /* Smooth fade effect for swiper - scoped to hero only */
      .hero-carousel.swiper .swiper-slide {
          opacity: 0;
          transition: opacity 0.6s ease;
      }

      .hero-carousel.swiper .swiper-slide-active {
          opacity: 1;
      }
  }

  /* Gradient Fade Overlay Effect - show only on ultra-wide screens */
  @media (min-width: 1510px) {
      .hero-carousel__fade-left,
      .hero-carousel__fade-right {
          opacity: 0;
      }
  }

  @media (min-width: 1520px) {
    .hero-carousel__fade-left,
    .hero-carousel__fade-right {
      opacity: 0.2;
    }
  }

  @media (min-width: 1530px) {
    .hero-carousel__fade-left,
    .hero-carousel__fade-right {
      opacity: 0.4;
    }
  }

  @media (min-width: 1540px) {
    .hero-carousel__fade-left,
    .hero-carousel__fade-right {
      opacity: 0.6;
    }
  }

  @media (min-width: 1550px) {
      .hero-carousel__fade-left,
      .hero-carousel__fade-right {
          opacity: 0.8;
      }
  }

  @media (min-width: 1560px) {
    .hero-carousel__fade-left,
    .hero-carousel__fade-right {
      opacity: 1;
    }

    .hero-carousel__video,
    .hero-carousel__image {
        padding-left: 2px;
        padding-right: 2px;
    }
  }

  /* Swiper pagination custom styles */
  .hero-carousel__pagination {
    display: flex;
    gap: 8px;
  }

  .hero-carousel__pagination .swiper-pagination-bullet {
    width: 36px;
    height: 8px;
    background: rgba(162, 161, 164, 0.6);
    border-radius: 100px;
    opacity: 1;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: width 0.3s ease, background 0.3s ease;
  }

  .hero-carousel__pagination .swiper-pagination-bullet-active {
    background: #a2a1a4;
  }

  .hero-carousel__pagination .swiper-pagination-bullet:not(.swiper-pagination-bullet-active) {
    width: 16px;
    background: rgba(162, 161, 164, 0.6);
  }

  .hero-carousel__progress-bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: #f2f2f2;
    border-radius: inherit;
    width: 0%;
    transition: width 0.1s linear;
  }

  /* Ensure progress bar only shows on active bullet */
  .hero-carousel__pagination .swiper-pagination-bullet:not(.swiper-pagination-bullet-active) .hero-carousel__progress-bar {
    width: 0% !important;
    display: none;
  }

  /* Focus styles for accessibility */
  .hero-carousel__button-prev:focus-visible,
  .hero-carousel__button-next:focus-visible,
  .hero-carousel__pagination .swiper-pagination-bullet:focus-visible {
    outline: 2px solid #c74f1f;
    outline-offset: 2px;
  }

  /* Scope bullet margin to hero carousel only */
  .hero-carousel__pagination .swiper-pagination-bullet {
      margin: 0 !important;
  }
</style>

<script src="{{ 'carousel.js' | asset_url }}" type="module"></script>

{% schema %}
{
  "name": "t:names.hero",
  "tag": "section",
  "class": "hero-wrapper section-wrapper",
  "max_blocks": 10,
  "blocks": [
    {
      "type": "_hero-slide"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:content.carousel_settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:settings.autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "label": "t:settings.autoplay_delay",
      "info": "Time each slide displays (in seconds)",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 6
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "t:settings.transition_speed",
      "info": "Slide transition duration (in milliseconds)",
      "min": 300,
      "max": 1500,
      "step": 100,
      "unit": "ms",
      "default": 600
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "vertical_position",
      "label": "Content Vertical Positioning",
      "options": [
        {
          "value": "top",
          "label": "t:options.top"
        },
        {
          "value": "bottom",
          "label": "t:options.bottom"
        }
      ],
      "default": "bottom"
    },
    {
      "type": "select",
      "id": "horizontal_position",
      "label": "Content Horizontal Positioning",
      "options": [
        {
          "value": "left",
          "label": "t:options.left"
        },
        {
          "value": "right",
          "label": "t:options.right"
        }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Hero: Homepage",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
