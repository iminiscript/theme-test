{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign config_id = section.id | replace: '-', '_' | replace: '--', '_'

  if section.settings.override_theme_swiper_settings
    assign autoplay_enabled = section.settings.autoplay_enabled
    assign autoplay_interval = section.settings.autoplay_interval | times: 1000
    assign animation_speed = section.settings.animation_speed
  else
    assign autoplay_enabled = settings.autoplay_enabled
    assign autoplay_interval = settings.autoplay_interval | times: 1000
    assign animation_speed = settings.animation_speed
  endif
-%}

<div class="social-reels-wrapper py-12 md:py-16 overflow-hidden {{ bg_color }}" data-section-id="{{ section.id }}">
  <div class="container-layout flex flex-col gap-5 md:gap-8">
    {%- if heading != blank or subheading != blank -%}
      <div class="flex flex-col gap-2 text-center px-3 md:px-8 lg:px-12">
        {%- if heading != blank -%}
          <h2 class="text-heading-4 text-balance {{ text_color }}">
            {{ heading }}
          </h2>
        {%- endif -%}

        {%- if subheading != blank -%}
          <p class="text-16-regular {{ text_color }}">
            {{ subheading }}
          </p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Carousel Container {%- endcomment -%}
    <div class="relative px-18 md:px-18 lg:px-0">
      <div class="swiper__carousel social-reels" data-config="SocialReelsConfig_{{ config_id }}">
        <div class="swiper-wrapper">
          {% capture slides %}
            {% content_for 'blocks' %}
          {%endcapture%}
          {% if section.blocks.size < 8 %}
            {{ slides }}
            {{ slides }}
          {% else %}
            {{ slides }}
          {% endif %}
        </div>
      </div>

      <button
        class="social-reels-nav-prev absolute left-3 md:left-8 lg:left-12 top-1/2 z-20 -translate-y-1/2 w-10 h-10 rounded-full bg-white border border-asphalt flex items-center justify-center hover:bg-light-smoke hover:scale-105 active:scale-95 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brunt-orange"
        aria-label="Previous review"
      >
        {% render 'icon', icon: 'pointer-arrow-left' %}
      </button>

      <button
        class="social-reels-nav-next absolute right-3 md:right-8 lg:right-12 top-1/2 z-20 -translate-y-1/2 w-10 h-10 rounded-full bg-white border border-asphalt flex items-center justify-center hover:bg-light-smoke hover:scale-105 active:scale-95 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brunt-orange"
        aria-label="Next review"
      >
        {% render 'icon', icon: 'pointer-arrow-right' %}
      </button>

      {%- comment -%} Pagination Dots {%- endcomment -%}
      {%- if section.blocks.size > 1 -%}
        <div class="social-reels-pagination flex justify-center gap-2 mt-5"></div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  // social-reels Carousel Configuration for {{ section.id }}
  window.SocialReelsConfig_{{ config_id }} = {
    breakpoints: {
        320: {
            slidesPerView: 'auto',
            spaceBetween: 16,
            centeredSlides: true,
        },
        768: {
            slidesPerView: 'auto',
            spaceBetween: 16,
            slidesOffsetBefore: 0,
            centeredSlides: true,
        },
        1280: {
            slidesPerView: 4,
            spaceBetween: 24,
            slidesOffsetBefore: 0,
            centeredSlides: false,
        },
    },
    loop: true,
    resizeObserver: false, // Disable resize observer for better performance
    speed: {{ animation_speed }},
    autoplay: {{ autoplay_enabled }} && !window.matchMedia("(prefers-reduced-motion: reduce)").matches ? {
      delay: {{ autoplay_interval }},
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    } : false,
    navigation: {
      nextEl: "[data-section-id='{{ section.id }}'] .social-reels-nav-next",
      prevEl: "[data-section-id='{{ section.id }}'] .social-reels-nav-prev",
    },
    pagination: {
      el: "[data-section-id='{{ section.id }}'] .social-reels-pagination",
      clickable: true,
      type: 'bullets',
      renderBullet: function (index, className) {
        return `<span class="${className}" role="button" aria-label="Go to slide ${index + 1}">
          <span class="social-reels-progress-bar"></span>
        </span>`;
      }
    },
    on: {
      init: function(swiper) {
        if (typeof window.attachPaginationHandlers === 'function') {
          window.attachPaginationHandlers(swiper, "[data-section-id='{{ section.id }}'] .social-reels-pagination");
        }
        if (typeof window.updateNavigationVisibility === 'function') {
          window.updateNavigationVisibility(swiper, '.social-reels-nav-prev', '.social-reels-nav-next');
        }
      },
      slideChange: function(swiper) {
        if (typeof window.updateNavigationVisibility === 'function') {
          window.updateNavigationVisibility(swiper, '.social-reels-nav-prev', '.social-reels-nav-next');
        }
      },
      resize: function(swiper) {
        if (typeof window.updateNavigationVisibility === 'function') {
          window.updateNavigationVisibility(swiper, '.social-reels-nav-prev', '.social-reels-nav-next');
        }
      },
      autoplayTimeLeft: function(swiper, time, progress) {
        if (typeof window.updateProgressBar === 'function') {
          window.updateProgressBar(
            swiper,
            progress,
            ".social-reels-wrapper",
            ".social-reels-pagination",
            ".social-reels-progress-bar"
          );
        }
      }
    }
  };
</script>

{{ 'social-reels.js' | asset_url | script_tag }}

<style>
  /* Swiper pagination custom styles */
  .social-reels-pagination {
    display: flex;
    gap: 8px;
  }

  .social-reels-pagination .swiper-pagination-bullet {
    width: 16px;
    height: 8px;
    background: var(--color-medium-asphalt);
    border-radius: 100px;
    opacity: 1;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: width 0.3s ease, background 0.3s ease;
  }

  .social-reels-pagination .swiper-pagination-bullet-active {
    width: 36px;
    {% if autoplay_enabled %}
      background: var(--color-medium-asphalt);
    {% else %}
      background: var(--color-brunt-orange);
    {% endif %}
  }

  .social-reels-progress-bar {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    background: var(--color-brunt-orange);
    border-radius: inherit;
    width: 0%;
    transition: width 0.1s linear;
  }

  /* Ensure progress bar only shows on active bullet */
  .social-reels-pagination .swiper-pagination-bullet:not(.swiper-pagination-bullet-active) .social-reels-progress-bar {
    width: 0% !important;
    display: none;
  }

  /* Scope bullet margin to hero carousel only */
  .social-reels-pagination .swiper-pagination-bullet {
      margin: 0 !important;
  }

  /* Slide transition styles */
  [data-section-id="{{ section.id }}"] .swiper-slide {
    height: auto;
    width: auto;
    display: flex;
  }

  /* Navigation arrow visibility transitions */
  .social-reels-nav-prev,
  .social-reels-nav-next {
    transition: opacity 0.3s ease, transform 0.2s ease;
  }

  @media (min-width: 1280px) {
    .swiper__carousel.social-reels .swiper-slide:nth-child(n + 5){
      display:none
    }

    .social-reels-pagination {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Social Reels (UGC)",
  "tag": "section",
  "class": "section-social-reels",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Trenches"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Highlighting the gnarliest content from the BRUNT community"
    },
    {
      "type": "checkbox",
      "id": "override_theme_swiper_settings",
      "label": "Swiper Override",
      "default": false,
      "info": "Override the default swiper theme settings"
    },
    {
      "type": "checkbox",
      "id": "autoplay_enabled",
      "label": "Enable Autoplay",
      "default": true,
      "info": "Automatically advances slides",
      "visible_if" : "{{ section.settings.override_theme_swiper_settings }}"
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay Interval (seconds)",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5,
      "info": "Time between slide transitions",
      "visible_if" : "{{ section.settings.override_theme_swiper_settings }}"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation Speed (ms)",
      "min": 200,
      "max": 1000,
      "step": 100,
      "default": 500,
      "info": "Speed of slide transitions",
      "visible_if" : "{{ section.settings.override_theme_swiper_settings }}"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": [
        { "value": "bg-white", "label": "White" },
        { "value": "bg-light-smoke", "label": "Light Smoke" },
        { "value": "bg-medium-smoke", "label": "Medium Smoke" },
        { "value": "bg-asphalt", "label": "Asphalt" }
      ],
      "default": "bg-white"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text Color",
      "options": [
        { "value": "text-black", "label": "Black" },
        { "value": "text-asphalt", "label": "Asphalt" },
        { "value": "text-medium-smoke", "label": "Medium Smoke" },
        { "value": "text-light-smoke", "label": "Light Smoke" },
        { "value": "text-white", "label": "White" }
      ],
      "default": "text-asphalt"
    }
  ],
  "blocks": [
    {
      "type": "_social-reel"
    }
  ],
  "presets": [
    {
      "name": "Social Reels (UGC)",
      "category": "Social Proof"
    }
  ]
}
{% endschema %}
