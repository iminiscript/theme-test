{% liquid
  assign section_title = section.settings.title
  assign tags_title = section.settings.tags_title
  assign section_id = 'key-features-' | append: section.id
  assign media_grid_id = section_id | append: '-media-grid'
  assign tags_list_id = section_id | append: '-tags-list'
%}
{%- liquid
  assign has_media_blocks = false
  assign has_tag_blocks = false
  for block in section.blocks
    if block.type == 'key_feature_media' and block.settings.title != blank
      assign has_media_blocks = true
    endif
    if block.type == 'key_feature_tag' and block.settings.tag_text != blank
      assign has_tag_blocks = true
    endif
  endfor
-%}

{%- if section.blocks.size > 0 and has_media_blocks or has_tag_blocks -%}
  <section
    class="key-features py-14 md:py-24 px-3 md:px-12"
    {%- if section_title != blank -%}
      aria-labelledby="{{ section_id }}-title"
    {%- else -%}
      aria-label="Key Features"
    {%- endif -%}
  >
    <div class="key-features__container max-w-[1000px] mx-auto flex flex-col gap-5 md:gap-8">
      {%- if section_title != blank -%}
        <h2 id="{{ section_id }}-title" class="key-features__title text-center uppercase text-heading-4">
          {{ section_title }}
        </h2>
      {%- endif -%}

      {%- if has_media_blocks -%}
        <ul
          id="{{ media_grid_id }}"
          class="key-features__media-grid grid grid-cols-2 gap-4 md:flex md:justify-center md:gap-5 lg:gap-6 list-unstyled"
          aria-label="{% if section_title != blank %}{{ section_title }}: {% endif %}Key feature media"
        >
          {%- for block in section.blocks -%}
            {%- if block.type == 'key_feature_media' -%}
              {%- liquid
                assign block_settings = block.settings
                assign media_image = block_settings.media
                assign item_title = block_settings.title

                # Alt text priority: image alt > item title > section title > generic fallback
                if media_image.alt != blank
                  assign image_alt = media_image.alt
                elsif item_title != blank
                  assign image_alt = item_title
                elsif section_title != blank
                  assign image_alt = section_title | append: ': Key feature image'
                else
                  assign image_alt = 'Key feature image'
                endif
              -%}
              <li class="key-features__media-item flex flex-col md:grow" {{ block.shopify_attributes }}>
                {%- if media_image != blank -%}
                  <div class="key-features__media-image h-full">
                    {% render 'image',
                      imageData: media_image,
                      class: 'key-features__image w-full',
                      width: media_image.width,
                      alt_text: image_alt
                    %}
                  </div>
                {%- endif -%}
                {%- if item_title != blank -%}
                  <p class="key-features__media-title text-18-regular mt-2">
                    {{ item_title }}
                  </p>
                {%- endif -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if has_tag_blocks -%}
        <div class="key-features__tags">
          {%- if tags_title != blank -%}
            <h3
              id="{{ section_id }}-tags-heading"
              class="key-features__tags-heading text-18-regular mb-4 text-center normal-case"
            >
              {{ tags_title }}
            </h3>
          {%- endif -%}

          {%- for block in section.blocks -%}
            {%- if block.type == 'key_feature_tag' -%}
              {%- liquid
                assign block_settings = block.settings
                assign tag_text = block_settings.tag_text
              -%}
              {{ tag_text }}
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .key-features {
    /* Ensure proper semantic structure */
  }

  .key-features__media-grid {
    /* Maintain list semantics while using grid/flex layout */
  }

  .key-features__tags ul {
    list-style-type: none;
    display: flex;
    gap: 8px;
    justify-content: center;
    align-items: center;
    padding-left: 0;
    margin: 0;
  }

  /* Ensure color contrast meets WCAG AA standards */
  .key-features__tags li {
    /* Black background (#000000) with white text (#ffffff) = 21:1 contrast ratio ✅ */
    /* Meets WCAG AAA standards for normal text */
    background-color: var(--color-asphalt);
    color: var(--color-white);
    padding: 4px 8px;
    font-family: var(--font-interstate);
    font-size: 12px;
    font-weight: 700;
    line-height: 16px;
    text-transform: uppercase;
    text-align: center;
    text-transform: uppercase;
  }

  .key-features__media-title,
  .key-features__tags-heading {
    /* text-asphalt should meet 4.5:1 contrast ratio on white background */
    /* Verify actual color value meets WCAG AA standards */
  }

  /* Respect reduced motion preferences */
  @media (prefers-reduced-motion: reduce) {
    .key-features * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* Ensure focus indicators are visible if any interactive elements are added */
  .key-features a:focus-visible,
  .key-features button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Key Features",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "FEATURES"
    },
    {
      "type": "text",
      "id": "tags_title",
      "label": "Tags Title",
      "default": "Best for:"
    }
  ],
  "blocks": [
    {
      "type": "key_feature_media",
      "name": "Key Feature Media",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature"
        },
        {
          "type": "image_picker",
          "id": "media",
          "label": "Media"
        }
      ]
    },
    {
      "type": "key_feature_tag",
      "name": "Key Feature Tag",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "tag_text",
          "label": "Tag Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Key Features",
      "blocks": [
        {
          "type": "key_feature_media",
          "settings": {
            "title": "Feature",
            "media": null
          }
        },
        {
          "type": "key_feature_media",
          "settings": {
            "title": "Feature",
            "media": null
          }
        }
      ],
      "settings": {
        "title": "FEATURES",
        "tags_title": "Best for:"
      }
    }
  ]
}
{% endschema %}
