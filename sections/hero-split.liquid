<div class="w-full {{ section.settings.background_color }}">
  <div class="max-w-[1440px] mx-auto w-full flex {% if section.settings.image_position == 'left' %}flex-col-reverse lg:flex-row-reverse{% else %}flex-col lg:flex-row{% endif %} lg:max-h-[800px]">
    <div class="w-full lg:w-1/3">
      <div class="h-full min-h-[240px] mx-auto px-3 py-6 md:px-8 lg:px-12 lg:py-12 flex flex-col justify-center items-center {{ section.settings.sm_content_gap }} {{ section.settings.md_content_gap }} {{ section.settings.lg_content_gap }} {{ section.settings.text_color }}" role="region" aria-label="Hero content">
        {% if section.settings.logo != blank %}
          {{ section.settings.logo | image_url: width: 460 | image_tag: loading: 'eager', class: 'h-fit max-w-[230px]', widths: '460', alt: 'Hero Brunt Logo' }}
        {% endif %}
        {% if section.settings.heading != blank %}
          <h1 class="w-full text-heading-2 {{ section.settings.text-layout }} {{ section.settings.lg-text-layout }}">
            {{ section.settings.heading }}
          </h1>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="w-full {{ section.settings.text-layout }} {{ section.settings.lg-text-layout }}">
            {{ section.settings.description }}
          </div>
        {% endif %}
        {% if section.blocks != blank %}
          <div class="w-auto gap-3 {{ section.settings.text-layout }} {{ section.settings.lg-text-layout }}">
            {% content_for 'blocks' %}
          </div>
        {% endif %}
      </div>
    </div>
    <div class="w-full lg:w-2/3 h-full">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'eager', class: 'h-full object-cover', widths: '375, 750, 1100, 1500, 1800', alt: section.settings.heading | default: 'Hero image' }}
      {% else %}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero: Split",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "button"
    }
  ],
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Building Something Better"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>We don't invest in innovation to create shiny objects that cost you more money. We create smart product solutions that improve performance, deliver more comfort, and extend the life of our products.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "background_color",
      "label": "Background Color",
      "options": [
        { "value": "bg-white","label": "White" },
        { "value": "bg-light-smoke", "label": "Light Smoke" },
        { "value": "bg-medium-smoke", "label": "Medium Smoke" },
        { "value": "bg-asphalt", "label": "Asphalt" }
      ],
      "default": "bg-asphalt"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text Color",
      "options": [
        { "value": "text-black", "label": "Black" },
        { "value": "text-asphalt", "label": "Asphalt" },
        { "value": "text-medium-smoke", "label": "Medium Smoke" },
        { "value": "text-light-smoke", "label": "Light Smoke" },
        { "value": "text-white","label": "White" }
      ],
      "default": "text-white"
    },
    {
      "type": "select",
      "id": "text-layout",
      "label": "Base Text Layout",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right", "label": "Right" }
      ],
      "default": "text-center"
    },
    {
      "type": "select",
      "id": "lg-text-layout",
      "label": "Desktop > Text Layout",
      "options": [
        { "value": "lg:text-left", "label": "Left" },
        { "value": "lg:text-center", "label": "Center" },
        { "value": "lg:text-right", "label": "Right" }
      ],
      "default": "lg:text-left"
    },
    {
      "type": "select",
      "id": "sm_content_gap",
      "label": "Mobile Content Gap",
      "options": [
        { "value": "gap-3", "label": "12px (default)" },
        { "value": "gap-4", "label": "16px" },
        { "value": "gap-5", "label": "20px" },
        { "value": "gap-6", "label": "24px" },
        { "value": "gap-7", "label": "28px" },
        { "value": "gap-8", "label": "32px" },
        { "value": "gap-10", "label": "40px" }
      ],
      "default": "gap-3"
    },
    {
      "type": "select",
      "id": "md_content_gap",
      "label": "Tablet Content Gap",
      "options": [
        { "value": "md:gap-3", "label": "12px (default)" },
        { "value": "md:gap-4", "label": "16px" },
        { "value": "md:gap-5", "label": "20px" },
        { "value": "md:gap-6", "label": "24px" },
        { "value": "md:gap-7", "label": "28px" },
        { "value": "md:gap-8", "label": "32px" },
        { "value": "md:gap-10", "label": "40px" }
      ],
      "default": "md:gap-3"
    },
    {
      "type": "select",
      "id": "lg_content_gap",
      "label": "Desktop Content Gap",
      "options": [
        { "value": "lg:gap-3", "label": "12px" },
        { "value": "lg:gap-4", "label": "16px" },
        { "value": "lg:gap-5", "label": "20px" },
        { "value": "lg:gap-6", "label": "24px" },
        { "value": "lg:gap-7", "label": "28px" },
        { "value": "lg:gap-8", "label": "32px (default)" },
        { "value": "lg:gap-10", "label": "40px" }
      ],
      "default": "lg:gap-8"
    }
  ],
  "presets": [
    {
      "name": "Hero: Split",
      "category": "t:categories.banners",
      "settings": {
        "heading": "This is a Heading",
        "description": "<p>Words are not just words, they mean things, you can say things that mean things through words. if you just read this you got absolutely no value from it. thanks for your time.</p>"
      }
    }
  ]
}
{% endschema %}

