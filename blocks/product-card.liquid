{% liquid
  assign product = block.settings.product
-%}

{% render 'product-card', product: product, section_name: 'global block' %}

{% schema %}
{
  "name": "t:names.product_card",
  "tag": null,
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:settings.product"
    }
  ],
  "presets": [
    {
      "name": "t:names.product_card",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
