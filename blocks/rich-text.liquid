<div class="rich-text-wrapper container-content flex flex-col gap-2 px-3 md:px-8 lg:px-0 pt-4 pb-8 md:pb-12 lg:pb-16">
  {% if page.title == 'Sitemap' %}
    {% render 'sitemap' %}
  {% else %}
    <h1 class="text-heading-3 text-center">{{ page.title }}</h1>
    <div class="flex flex-col gap-3">
      {{ page.content }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "t:names.page_content"
}
{% endschema %}
