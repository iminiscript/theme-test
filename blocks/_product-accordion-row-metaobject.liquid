{% liquid
  assign metafield_reference = block.settings.metafield_reference
%}
{%- if metafield_reference != blank -%}
  {% for item in metafield_reference %}
    {% assign title = item.title %}
    {% assign content = item.content %}
    <accordion-custom class="product__accordionRow" {{ block.shopify_attributes }}>
      <details
        class="border-medium-smoke border-b-1 py-6"
        data-testid="accordion-details"
      >
        <summary
          id="product-accordion-trigger-{{ block.id }}-{{ forloop.index }}"
          class="flex p-0 font-bold cursor-pointer focus-visible:outline-2 focus-visible:outline-offset-12 focus-visible:outline-brunt-orange"
          aria-expanded="false"
          aria-controls="product-accordion-content-{{ block.id }}-{{ forloop.index }}"
          role="button"
          tabindex="0"
          aria-describedby="product-accordion-description-{{ block.id }}-{{ forloop.index }}"
        >
          <h5 class="text-14-bold m-0 p-0 uppercase">
            {{ title }}
          </h5>
          <span
            id="product-accordion-description-{{ block.id }}-{{ forloop.index }}"
            class="svg-wrapper icon-caret icon-animated w-4 h-4"
            aria-hidden="true"
          >
            {% render 'icons', icon: 'chevron-down' %}
          </span>
        </summary>

        <div
          id="product-accordion-content-{{ block.id }}-{{ forloop.index }}"
          class="details-content pt-5"
          role="region"
          aria-labelledby="product-accordion-trigger-{{ block.id }}-{{ forloop.index }}"
        >
          {{ content | metafield_tag }}
        </div>
      </details>
    </accordion-custom>
  {% endfor %}
{%- endif -%}

{% schema %}
{
  "name": "Product Accordion Row",
  "tag": null,
  "settings": [
    {
      "type": "metaobject_list",
      "id": "metafield_reference",
      "label": "Metafield",
      "metaobject_type": "product_accordion"
    }
  ],
  "presets": [
    {
      "name": "Product Accordion Row from Metaobject"
    }
  ]
}
{% endschema %}
