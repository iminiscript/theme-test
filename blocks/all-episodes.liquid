{% assign blog = blogs[block.settings.blog] %}

<div id="all-episodes" class="bg-white px-3 md:px-8 lg:px-12 py-12 md:py-16">
  <div class="container-layout flex flex-col gap-5 md:gap-8">
    <div class="">
      <h2 class="text-asphalt text-heading-4 mb-1">{{ block.settings.heading }}</h2>
      <p class="text-asphalt text-14-light">{{ block.settings.subheading }} ({{ blog.articles_count }})</p>
    </div>

    {% comment %} paginate controls show differently depending on page seleted {% endcomment %}
    {% if current_page > 2 %}
      {%- paginate blog.articles by block.settings.posts_per_page, window_size: 2 -%}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-8 md:gap-y-16 gap-x-5 lg:gap-x-6 mb-10">
          {%- for article in blog.articles -%}
            {% render 'podcast-article-card', article: article %}
          {%- endfor -%}
        </div>

        <div class="flex gap-2 items-center justify-center bucket-talk-pagination">
          {%- if paginate.previous %}
            <a href="{{ paginate.previous.url }}#all-episodes" class="bg-white border border-brunt-orange w-12 h-12 flex items-center justify-center bucket-talk-pagination-link">
              {% render 'icons', icon: 'chevron-left', fill:"#c74f1f" %}
            </a>
          {% endif %}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}#all-episodes" class="bg-white border border-medium-smoke w-12 h-12 flex items-center justify-center text-14-light text-asphalt no-underline bucket-talk-pagination-link">
                {{ part.title }}
              </a>
            {%- else -%}
              <span class="{% if paginate.current_page == part.title %}bg-brunt-orange w-12 h-12 flex items-center justify-center text-white {% else %} text-asphalt px-2 {% endif %} text-14-light ">
                  {{ part.title }}
                </span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}#all-episodes" class="bg-white border border-brunt-orange w-12 h-12 flex items-center justify-center bucket-talk-pagination-link">
              {% render 'icons', icon: 'chevron-right', fill:"#c74f1f" %}
            </a>
          {%- endif -%}
        </div>
      {%- endpaginate -%}
    {% else %}
      {%- paginate blog.articles by block.settings.posts_per_page, window_size: 3 -%}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-y-8 md:gap-y-16 gap-x-5 lg:gap-x-6 mb-10">
          {%- for article in blog.articles -%}
            {% render 'podcast-article-card', article: article %}
          {%- endfor -%}
        </div>

        <div class="flex gap-2 items-center justify-center bucket-talk-pagination">
          {%- if paginate.previous %}
            <a href="{{ paginate.previous.url }}#all-episodes" class="bg-white border border-brunt-orange w-12 h-12 flex items-center justify-center bucket-talk-pagination-link">
              {% render 'icons', icon: 'chevron-left', fill:"#c74f1f" %}
            </a>
          {% endif %}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}#all-episodes" class="bg-white border border-medium-smoke w-12 h-12 flex items-center justify-center text-14-light text-asphalt no-underline bucket-talk-pagination-link">
                {{ part.title }}
              </a>
            {%- else -%}
              <span class="{% if paginate.current_page == part.title %}bg-brunt-orange w-12 h-12 flex items-center justify-center text-white {% else %} text-asphalt px-2 {% endif %} text-14-light ">
              {{ part.title }}
            </span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}#all-episodes" class="bg-white border border-brunt-orange w-12 h-12 flex items-center justify-center bucket-talk-pagination-link">
              {% render 'icons', icon: 'chevron-right', fill:"#c74f1f" %}
            </a>
          {%- endif -%}
        </div>
      {%- endpaginate -%}
    {% endif %}
  </div>
</div>

<script>
  (function() {
    // Scroll to #all-episodes section on page load if hash is present
    function scrollToAllEpisodes() {
      if (window.location.hash === '#all-episodes') {
        setTimeout(function() {
          const allEpisodesSection = document.getElementById('all-episodes');
          if (allEpisodesSection) {
            allEpisodesSection.scrollIntoView({ 
              behavior: 'smooth',
              block: 'start'
            });
          }
        }, 100);
      }
    }
    
    // Initialize on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', scrollToAllEpisodes);
    } else {
      scrollToAllEpisodes();
    }
    
    // Also handle hash changes (in case user navigates with back/forward buttons)
    window.addEventListener('hashchange', scrollToAllEpisodes);
  })();
</script>

{% schema %}
{
  "name": "All Episodes",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "All Episodes"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "All Episodes"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog",
      "info": "Select the blog to display episodes from"
    },
    {
      "type": "range",
      "id": "posts_per_page",
      "label": "Posts Per Page",
      "min": 3,
      "max": 30,
      "step": 3,
      "default": 9,
      "info": "The amount of blog posts per paginated page"
    }
  ],
  "presets": [
    {
      "name": "All Episodes",
      "category": "Bucket Talk"
    }
  ]
}
{% endschema %}

