{% liquid
  assign _section = block.settings
  assign _collection = _section.collection
  assign _discount_percentage = _section.discount_percentage
  assign _bundle_cart_image = _section.bundle_cart_image
  assign products = _collection.products

  # Calculate minimum price from all products in this collection
  assign min_price = 999999999
  for product in products
    if product.price < min_price
      assign min_price = product.price
    endif
  endfor
  # If no products, set to 0
  if products.size == 0
    assign min_price = 0
  endif
%}

<bundle-collection-component class="block" data-skip-subtree-update="true" data-min-price="{{ min_price }}">
  <div
    class="bundle-collection__scroll flex gap-3 flex-nowrap overflow-x-scroll md:flex-wrap md:overflow-visible -mr-3 md:mr-0 pb-2 md:pb-0"
    ref="productsContainer"
  >
    {% for product in products %}
      <div
        class="p-2 min-w-[112px] max-w-[112px] border border-[#E1E1D9] cursor-pointer hover:border-asphalt transition-all duration-300"
        data-product-handle="{{ product.handle }}"
      >
        <img
          class="mb-2"
          src="{{ product.featured_image | image_url: width: 100 }}"
          alt="{{ product.title }}"
          width="100"
          height="100"
          loading="lazy"
        >
        <p class="text-14-light text-center pb-2">{{ product.title }}</p>
      </div>
    {% endfor %}
  </div>
</bundle-collection-component>

<script src="{{ 'bundle-collection.js' | asset_url }}" defer="defer" type="module"></script>

<style>
  .bundle-collection__scroll {
    /* Firefox */
    scrollbar-width: thin;
    scrollbar-color: #a2a1a4 #e1e1d9;
  }

  .bundle-collection__scroll::-webkit-scrollbar {
    height: 4px;
  }

  .bundle-collection__scroll::-webkit-scrollbar-track {
    background: #e1e1d9;
  }

  .bundle-collection__scroll::-webkit-scrollbar-thumb {
    background: #a2a1a4;
  }

  .bundle-collection__scroll::-webkit-scrollbar-thumb:hover {
    background: #8a898c;
  }

  @media (min-width: 768px) {
    .bundle-collection__scroll::-webkit-scrollbar {
      display: none;
    }
    .bundle-collection__scroll {
      scrollbar-width: none;
    }
  }
</style>

{% schema %}
{
  "name": "Bundle Collection",
  "class": "bundle__collection",
  "presets": [
    {
      "name": "Bundle Collection"
    }
  ],
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "The collection to display the products from"
    }
  ]
}
{% endschema %}
