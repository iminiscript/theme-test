{% liquid
  assign product = closest.product
%}
<div data-section-id="{{ section.id }}" {{ block.shopify_attributes }}>
  <h3 class="product__featuresTitle text-14-bold m-0">{{ product.metafields.custom.product_features_title }}</h3>
  <div class="product__featureList text-14-light">
    {{ product.metafields.custom.product_features | metafield_tag }}
  </div>
</div>

{% stylesheet %}
  .product__featureList ul {
    list-style-type: '•   ';
    margin-left: 8px;
    padding-left: 12px;
    font-size: 14px;
    line-height: 20px;
    font-weight: 300;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Features",
  "class": "product__features flex flex-col gap-3",
  "tag": "div",
  "presets": [
    {
      "name": "Product Features"
    }
  ]
}
{% endschema %}
