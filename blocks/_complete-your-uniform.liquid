{% schema %}
  {
    "name": "Complete Your Uniform",
    "class": "complete-your-uniform",
    "tag": "div",
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Complete Your Uniform"
      }
    ],
    "presets": [
      {
        "name": "Complete Your Uniform"
      }
    ]
  }
{% endschema %}
