{%- liquid
  # Get products from metafield
  assign complete_your_uniform_products = product.metafields.custom.complete_your_uniform.value

  assign title = block.settings.title
  
  # Get section ID for product forms
  if section.id
    assign section_id = section.id
  else
    assign section_id = 'complete-your-uniform'
  endif
-%}

  
  {%- if complete_your_uniform_products != blank and complete_your_uniform_products.size > 0 -%}
    {% render 'cart-upsell',
      products: complete_your_uniform_products,
      section_id: section_id,
      title: title,
      context: 'pdp',
      limit: 10,
      item_class: 'border border-medium-smoke complete-uniform'
    %}
  {%- else -%}
    <div class="text-center py-8">
      <p class="text-14-regular">No products available to complete your uniform.</p>
    </div>
  {%- endif -%}

