  {
    "name": "t:names.cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "t:settings.cart_type",
        "options": [
          {
            "value": "page",
            "label": "t:options.page"
          },
          {
            "value": "drawer",
            "label": "t:options.drawer"
          }
        ],
        "default": "page"
      },
      {
        "type": "select",
        "id": "product_title_case",
        "label": "t:settings.product_title_case",
        "options": [
          {
            "value": "default",
            "label": "t:options.default"
          },
          {
            "value": "uppercase",
            "label": "t:options.uppercase"
          }
        ],
        "default": "default"
      },
      {
        "type": "select",
        "id": "cart_price_font",
        "label": "t:settings.font_price",
        "options": [
          {
            "value": "primary",
            "label": "t:options.body"
          },
          {
            "value": "secondary",
            "label": "t:options.subheading"
          },
          {
            "value": "tertiary",
            "label": "t:options.tertiary"
          }
        ],
        "default": "secondary"
      },
      {
        "type": "checkbox",
        "id": "auto_open_cart_drawer",
        "label": "t:settings.auto_open_cart_drawer",
        "default": true,
        "visible_if": "{{ settings.cart_type == 'drawer' }}"
      },
      {
        "type": "checkbox",
        "id": "show_cart_note",
        "label": "t:settings.seller_note",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "cart_note_open_by_default",
        "label": "t:settings.seller_note_open_by_default",
        "default": false,
        "visible_if": "{{ settings.show_cart_note == true }}"
      },
      {
        "type": "checkbox",
        "id": "show_add_discount_code",
        "label": "t:settings.add_discount_code",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_installments",
        "label": "t:settings.installments",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_accelerated_checkout_buttons",
        "label": "t:settings.checkout_buttons",
        "info": "t:info.checkout_buttons",
        "default": true
      },
      {
        "type": "header",
        "content": "Cart Progress Bar"
      },
      {
        "type": "checkbox",
        "id": "enable_gwp",
        "label": "Enable Gift With Purchase (GWP) - US",
        "info": "You can have a maximum of four thresholds and a minimum of one; if you only want one threshold, set the remaining amounts to 0 and leave the corresponding labels empty. The starting value is automatically set to zero; you just need to fill in the label information."
      },
      {
        "type": "checkbox",
        "id": "enable_cart_bar_int",
        "label": "Enable Cart Progress Bar - INT",
        "default": false,
        "info": "By checking this, Cart Progress bar will be visible for INT"
      },
      {
        "type": "checkbox",
        "id": "enable_global_bar",
        "label": "Enable Global Promo - US",
        "default": false,
        "info": "By checking this, Progress bar will be visible in Header instead of Announcement bar when cart isn't empty."
      },
      {
        "type": "checkbox",
        "id": "enable_promo_bar_int",
        "label": "Enable Global Promo Bar - INT",
        "default": false,
        "info": "By checking this, Progress bar will be visible for INT on Header but in order to work this our cart bar should have been active"
      },
      {
        "type": "range",
        "id": "add_gwp_tier",
        "label": "Select the Tier where GWP will add in cart",
        "min": 1,
        "max": 4,
        "step": 1,
        "default": 1,
        "info": "Select a value between 1 and 4. The Gift With Purchase (GWP) will be added at the corresponding tier based on your selection."
      },
      {
        "type": "radio",
        "id": "gwp_cart_price_type",
        "label": "Which Cart Total Should Count Toward Rewards?",
        "options": [
          {
            "value": "total_price",
            "label": "Final Price (After Discounts & Promo Codes)"
          },
          {
            "value": "original_total_price",
            "label": "Original Price (Before Any Discounts)"
          }
        ],
        "default": "total_price",
        "info": "Choose whether customers need to reach the threshold using their final discounted price or their original price before discounts. For example: If a customer has $100 in their cart but uses a 20% discount code, their final price is $80. Selecting 'Final Price' means they need $80 to reach a $50 threshold. Selecting 'Original Price' means they need $100 to reach a $50 threshold."
      },
      {
        "type": "header",
        "content": "Gift With Purchase Product"
      },
      {
        "type": "product",
        "id": "gwp_product",
        "label": "Select Gift Product",
        "info": "Choose the product that will be automatically added to the cart as a free gift when customers reach the selected threshold tier. This product will be added automatically when the cart total meets or exceeds the threshold amount you've configured above. Make sure the selected product is set up as a free item or has a price of $0."
      },
      {
        "type": "header",
        "content": "GWP Threshold Configuration"
      },
      {
        "type": "paragraph",
        "content": "Configure up to four spending thresholds for your Gift With Purchase progress bar. Each threshold represents a milestone where customers can unlock rewards. Thresholds must be set in ascending order (each threshold must be higher than the previous one)."
      },
      {
        "type": "text",
        "id": "gwp_threshold_label_zero",
        "label": "Starting Point Label",
        "info": "The label displayed at the beginning of the progress bar (when cart total is $0). This is typically used to indicate the starting point or initial state.",
        "placeholder": "e.g., Start Shopping, $0"
      },
      {
        "type": "number",
        "id": "gwp_threshold",
        "default": 0,
        "label": "First Threshold Amount",
        "info": "Enter the minimum cart value (in dollars) required to reach the first milestone. This must be greater than $0 to activate the first threshold.",
        "placeholder": "e.g., 50"
      },
      {
        "type": "text",
        "id": "gwp_threshold_label",
        "label": "First Threshold Label",
        "info": "The reward message or milestone description displayed when customers reach the first threshold amount.",
        "placeholder": "e.g., Free Shipping, Unlock First Reward",
        "visible_if": "{{ settings.gwp_threshold > 0 }}"
      },
      {
        "type": "number",
        "id": "gwp_threshold_two",
        "default": 0,
        "label": "Second Threshold Amount",
        "info": "Enter the minimum cart value (in dollars) required to reach the second milestone. This must be greater than the first threshold amount.",
        "placeholder": "e.g., 100",
        "visible_if": "{{ settings.gwp_threshold > 0 }}"
      },
      {
        "type": "text",
        "id": "gwp_threshold_label_two",
        "label": "Second Threshold Label",
        "info": "The reward message or milestone description displayed when customers reach the second threshold amount.",
        "placeholder": "e.g., Bonus Gift, Unlock Second Reward",
